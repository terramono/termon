{
    "defwidget@terminal": {
        "display:order": -5,
        "icon": "brands@anthropic",
        "label": "claude",
        "description": "Launch Claude Code",
        "blockdef": {
            "meta": {
                "view": "term",
                "controller": "cmd",
                "cmd": "claude",
                "cmd:interactive": true,
                "claude:launcher": true
            }
        }
    },
    "defwidget@files": {
        "display:order": -4,
        "icon": "folder",
        "color": "#2eff6a",
        "label": "files",
        "blockdef": {
            "meta": {
                "view": "preview",
                "file": "~"
            }
        }
    },
    "defwidget@web": {
        "display:order": -3,
        "icon": "globe",
        "color": "#2eff6a",
        "label": "web",
        "blockdef": {
            "meta": {
                "view": "web"
            }
        }
    },
    "defwidget@sysinfo": {
        "display:order": -2,
        "icon": "chart-line",
        "color": "#2eff6a",
        "label": "sysinfo",
        "blockdef": {
            "meta": {
                "view": "sysinfo"
            }
        }
    }
}
